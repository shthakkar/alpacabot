# Copy this file to `.env` and fill in your Alpaca credentials.
# Get keys from https://app.alpaca.markets/  (use PAPER keys to start).
# The .env file is gitignored — never commit real keys.

ALPACA_API_KEY=your_key_here
ALPACA_API_SECRET=your_secret_here

# "true" = paper trading account (safe). Set to "false" only for live trading.
ALPACA_PAPER=true
